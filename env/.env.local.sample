# Copy this file to ~/.env.local and fill in the values
# ~/.env.local must never be committed

# GitHub Container Registry token
# Used by: alias login_ghcr
export CR_PAT=

# ─────────────────────────────────────────────────────────────────────────────
# Git: create ~/.gitconfig.work to override the email in ebanx repos
#
# ~/.gitconfig.work
# [user]
#     email = andre.ribas@ebanx.com
